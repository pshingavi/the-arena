# ============================================
# THE ARENA - Environment Variables
# ============================================
# Copy this to .env and fill in your keys

# --- LLM (Anthropic Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Voice (ElevenLabs) ---
# Used as fallback when HeyGen is NOT configured
ELEVENLABS_API_KEY=...
# Voice IDs per guest (comma-separated key:value pairs)
# Get voice IDs from your ElevenLabs dashboard after cloning/selecting voices
# Format: "Guest Name:voice_id,Guest Name 2:voice_id2"
ELEVENLABS_VOICE_MAP=
# Default voice if no mapping found
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Video Avatars (HeyGen) ---
# ── MVP / ElevenLabs-only mode ───────────────────────────────────────────────
# Set DISABLE_HEYGEN=true to force ElevenLabs-only mode even when all HeyGen
# credentials are present.  Recommended for initial production launches.
DISABLE_HEYGEN=true

# ── Full HeyGen mode (real-time avatar video) ─────────────────────────────────
# When DISABLE_HEYGEN is removed/false and HeyGen is fully configured:
#   • Audio comes from HeyGen TTS (ElevenLabs is bypassed)
#   • Text typewriter is synced to video duration
#   • Next turn only starts when video ends
#
# Setup steps:
#   1. Remove or set DISABLE_HEYGEN=false above
#   2. Set HEYGEN_API_KEY below
#   2. cd backend && python discover_heygen_avatars.py   → paste HEYGEN_MALE/FEMALE_AVATAR_ID
#   3. cd backend && python discover_heygen_voices.py    → paste HEYGEN_MALE/FEMALE_VOICE_ID
#   4. Optionally add per-guest overrides in HEYGEN_AVATAR_MAP / HEYGEN_VOICE_MAP
HEYGEN_API_KEY=...

# Gender-specific avatar defaults
# Run: python discover_heygen_avatars.py  to find these IDs
HEYGEN_MALE_AVATAR_ID=
HEYGEN_FEMALE_AVATAR_ID=
# Backward-compat single default (used only if no gender-specific IDs are set)
HEYGEN_DEFAULT_AVATAR_ID=

# Optional: per-guest avatar overrides (generated by discover_heygen_avatars.py)
# Format: "Guest Name:avatar_id,Guest Name 2:avatar_id2"
HEYGEN_AVATAR_MAP=

# Gender-specific TTS voice defaults
# Run: python discover_heygen_voices.py  to find these IDs
HEYGEN_MALE_VOICE_ID=
HEYGEN_FEMALE_VOICE_ID=
# Backward-compat single default (used only if no gender-specific IDs are set)
HEYGEN_DEFAULT_VOICE_ID=

# Optional: per-guest voice overrides (generated by discover_heygen_voices.py)
# Format: "Guest Name:voice_id,Guest Name 2:voice_id2"
HEYGEN_VOICE_MAP=

# --- App Config ---
CORS_ORIGINS=http://localhost:3001
DATA_DIR=./data
CHROMA_PERSIST_DIR=./chroma_db

# API base URL for absolute audio URLs
API_BASE_URL=http://localhost:8002
